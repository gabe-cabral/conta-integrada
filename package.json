{
  "name": "conta-integrada",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "imports": {
    "#shared/*.ts": "./shared/*.ts",
    "#shared/*": "./shared/*.ts",
    "#server/*.ts": "./server/*.ts",
    "#server/*": "./server/*.ts",
    "#setup/*.ts": "./setup/*.ts",
    "#setup/*": "./setup/*.ts"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:setup": "node --experimental-strip-types --env-file=.env ./setup/database/index.ts",
    "db:load": "node --experimental-strip-types --env-file=.env ./setup/load/index.ts"
  },
  "dependencies": {
    "@nuxt/eslint": "^1.12.1",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/hints": "^1.0.0-alpha.5",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "1.3",
    "@pinia/nuxt": "^1.0.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@t3-oss/env-nuxt": "^0.13.11",
    "@unhead/vue": "^3.1.8",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "decimal.js": "^10.6.0",
    "eslint": "^10.7.0",
    "h3": "^2.0.1-rc.25",
    "mongodb": "^7.1.0",
    "mongodb-client-encryption": "^7.0.0",
    "nuxt": "^4.2.2",
    "nuxt-auth-utils": "^0.5.29",
    "pinia": "^4.0.2",
    "tom-select": "^2.6.2",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vue": "^3.5.26",
    "vue-router": "5.2",
    "zod": "^4.3.5",
    "zod-to-mongo-schema": "^1.1.2",
    "zodson": "^1.0.1"
  },
  "devDependencies": {
    "@nexso/eslint-config": "^3.0.0",
    "@nexso/eslint-config-typescript": "^2.0.0",
    "@types/bootstrap": "^5.2.11",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.5",
    "sass-embedded": "^1.97.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "allowScripts": {
    "mongodb-client-encryption@7.2.0": true
  }
}
